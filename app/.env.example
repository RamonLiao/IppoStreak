# Copy to .env.local (gitignored) and fill the two values below.
# All VITE_* vars are bundled into the browser — only use values safe to expose publicly.

# --- Frontend-public credentials (NOT secrets) ---
# VITE_ENOKI_API_KEY: use the Enoki PUBLIC api key (starts with enoki_public_...).
#   NEVER put a private/secret Enoki key here — VITE_* is shipped to the browser.
# VITE_GOOGLE_CLIENT_ID: OAuth client id (public by design).
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# --- Public on-chain ids (testnet). PKG = upgraded v2 call target. ---
VITE_PKG=0x70dce2dc9a4fbc2beb4c1047ecb3deb400bc068d0670a5bb29b8c22a9751e254
VITE_LEAGUE=0x2e1cad6d4fe097bb2315e0524d703614db7eb0c14970e4d459989d477d8a716c
VITE_SUB_REGISTRY=0x506c64d6dbf556cca578d57d8ccf8a5d594d9809e33e333651a357cd40f5088b
